{
  "name": "homebase",
  "version": "0.1.0",
  "description": "Self-hosted file server — stream and manage files from your local drive via a web UI.",
  "author": ["SiddharthGanesh2001", "shreyaslink3d"],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:clean": "rm -rf coverage .vitest-cache",
    "test:watch": "vitest",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "knip": "^5.0.0",
    "lint-staged": "^16.1.0",
    "madge": "^8.0.0",
    "tsc-alias": "^1.8.7",
    "tsx": "^4.19.4",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
